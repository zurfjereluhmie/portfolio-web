{
  "name": "nuxt-app",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"{components,pages,plugins,middleware,layouts,composables,assets,tests}/**/*.{js,jsx,ts,tsx,vue,html,css,scss,json,md}\"",
    "tsc": "tsc --noEmit"
  },
  "dependencies": {
    "@intlify/core-base": "^11.3.0",
    "@intlify/shared": "^11.3.2",
    "@nuxt/content": "^3.13.0",
    "@nuxt/image": "^2.0.0",
    "@nuxtjs/color-mode": "^4.0.0",
    "@nuxtjs/i18n": "^10.2.4",
    "@nuxtjs/seo": "^3.4.0",
    "@nuxtjs/tailwindcss": "^6.14.0",
    "better-sqlite3": "^12.9.0",
    "@lucide/vue": "^1.7.0",
    "nuxt": "^4.4.2",
    "vue": "latest",
    "vue-router": "^5"
  },
  "devDependencies": {
    "@nuxt/eslint": "^1.15.2",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/typography": "^0.5.19",
    "@types/node": "^25.6.0",
    "@vue/typescript-plugin": "^3.2.7",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "prettier": "^3.8.1",
    "typescript": "^6.0.3"
  }
}